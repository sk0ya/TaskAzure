<Window x:Class="TaskAzure.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TaskAzure - 設定"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCDDFF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8899BB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#333355"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444466"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#663333"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">

        <!-- タイトル -->
        <TextBlock Text="Azure DevOps 設定" FontSize="18" FontWeight="SemiBold"
                   Foreground="White" Margin="0,0,0,20"/>

        <!-- Organization URL -->
        <TextBlock Style="{StaticResource LabelStyle}" Text="Organization URL *"/>
        <TextBox x:Name="OrgUrlBox" Margin="0,0,0,14"
                 ToolTip="例: https://dev.azure.com/myorganization"/>
        <TextBlock Text="例: https://dev.azure.com/myorganization" Style="{StaticResource LabelStyle}"
                   Foreground="#556677" Margin="0,-12,0,14"/>

        <!-- Project -->
        <TextBlock Style="{StaticResource LabelStyle}" Text="プロジェクト名 *"/>
        <TextBox x:Name="ProjectBox" Margin="0,0,0,14"
                 ToolTip="Azure DevOps のプロジェクト名"/>

        <!-- PAT 環境変数名 -->
        <TextBlock Style="{StaticResource LabelStyle}" Text="PAT 環境変数名"/>
        <TextBox x:Name="PatEnvVarBox" Margin="0,0,0,4"
                 FontFamily="Consolas"
                 ToolTip="PAT を読み取る環境変数名。デフォルトは ADO_PAT。"/>
        <TextBlock x:Name="EnvPatStatus" Style="{StaticResource LabelStyle}"
                   Foreground="#557755" Margin="0,0,0,4"
                   Text="{Binding EnvPatValue}"/>
        <TextBlock Style="{StaticResource LabelStyle}" Foreground="#445566" Margin="0,0,0,14"
                   Text="指定した環境変数 → Windows 資格情報マネージャー の順で PAT を取得します。"/>

        <!-- 更新間隔 -->
        <TextBlock Style="{StaticResource LabelStyle}" Text="自動更新間隔 (分)"/>
        <TextBox x:Name="RefreshBox" Width="80" HorizontalAlignment="Left" Margin="0,0,0,14"/>

        <CheckBox x:Name="StartupCheck" Margin="0,0,0,20"
                  IsChecked="{Binding RunAtStartup, Mode=TwoWay}"
                  Foreground="#CCDDFF" FontSize="12" Cursor="Hand">
            Windows 起動時に自動起動する
        </CheckBox>

        <!-- PR 対象リポジトリ -->
        <TextBlock Style="{StaticResource LabelStyle}" Text="PR 対象リポジトリ (複数指定可)" Margin="0,0,0,6"/>

        <!-- 登録済みリスト -->
        <Border Background="#1A2233" BorderBrush="#334466" BorderThickness="1"
                CornerRadius="4" Padding="4" MinHeight="36" MaxHeight="140" Margin="0,0,0,6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 空のときのプレースホルダー -->
                    <TextBlock Text="（未設定）" Foreground="#445566" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PrTargets.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding PrTargets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}"
                                               Foreground="#AABBDD" FontSize="12"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                    <Button Grid.Column="1" Content="削除"
                                            Style="{StaticResource DangerBtn}"
                                            Tag="{Binding}"
                                            Click="RemovePrTarget_Click"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 追加フォーム -->
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="PrProjectBox" Grid.Column="0"
                     ToolTip="プロジェクト名"/>
            <TextBox x:Name="PrRepoBox" Grid.Column="2"
                     ToolTip="リポジトリ名"/>
            <Button Grid.Column="4" Content="追加"
                    Style="{StaticResource SecondaryBtn}"
                    Padding="14,6"
                    Click="AddPrTarget_Click"/>
        </Grid>
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="プロジェクト名"
                       Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="リポジトリ名"
                       Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
        </Grid>

        <!-- エラー表示 -->
        <TextBlock x:Name="ErrorText" Foreground="#FF6666" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,12" Visibility="Collapsed"/>

        <!-- ボタン行 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="保存" Style="{StaticResource PrimaryBtn}" Click="Save_Click"
                    IsDefault="True"/>
        </StackPanel>

    </StackPanel>
</Window>
