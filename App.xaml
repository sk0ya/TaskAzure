<Application x:Class="TaskAzure.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <Style x:Key="AppDarkComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#667799"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AppDarkComboEditableTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#252B42"/>
            <Setter Property="Foreground" Value="#EAF6FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="3,1,20,1"/>
            <Setter Property="CaretBrush" Value="#FFFFFF"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SelectionBrush" Value="#2A3A5A"/>
            <Setter Property="SelectionOpacity" Value="1"/>
        </Style>

        <Style x:Key="AppDarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextElement.Foreground" Value="#DDEEFF"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource AppDarkComboBoxItemStyle}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style x:Key="{x:Static ComboBox.TextBoxStyleKey}"
                       TargetType="{x:Type TextBox}"
                       BasedOn="{StaticResource AppDarkComboEditableTextBoxStyle}"/>
            </Style.Resources>
        </Style>
    </Application.Resources>
</Application>
