<Window x:Class="TaskAzure.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="clr-namespace:TaskAzure.ViewModels"
       WindowStyle="None"
       AllowsTransparency="True"
       Background="Transparent"
       Topmost="True"
       ShowInTaskbar="False"
       Width="260"
       MinHeight="30"
       SizeToContent="Height"
       MaxHeight="600"
       ResizeMode="NoResize"
       PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Margin="5" CornerRadius="7">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#E6141420"/>
                <Setter Property="BorderBrush" Value="#330078D4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                        <Setter Property="BorderBrush" Value="#AA0078D4"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="1" Opacity="0.55"/>
        </Border.Effect>

        <!-- WorkItem リスト -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 空状態 -->
                <TextBlock Foreground="#334455" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="— なし —"/>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding WorkItems}" Padding="3,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkItemViewModel}">
                            <Border Tag="{Binding}" Padding="6,4" CornerRadius="4"
                                    Background="Transparent">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Web で開く (_W)"
                                                  Click="MenuOpenWeb_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="ID をコピー (_I)"
                                                  Click="MenuCopyId_Click" Tag="{Binding}"/>
                                        <MenuItem Header="タイトルをコピー (_T)"
                                                  Click="MenuCopyTitle_Click" Tag="{Binding}"/>
                                        <MenuItem Header="リンクを作成 (_L)"
                                                  Click="MenuCreateLink_Click" Tag="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#18FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding TypeShort}"
                                               Foreground="{Binding TypeColor}"
                                               FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="#CCDAEE"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               ToolTip="{Binding Title}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- PR セクション (PR が 0 件のときは非表示) -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PullRequests.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- 区切り線 -->
                    <Rectangle Height="1" Margin="6,4,6,0" Fill="#22AACCFF"/>

                    <!-- PR ヘッダー -->
                    <TextBlock Text="Pull Requests"
                               Foreground="#556699" FontSize="10" FontWeight="SemiBold"
                               Margin="8,3,0,1"/>

                    <ItemsControl ItemsSource="{Binding PullRequests}" Padding="3,2">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PullRequestViewModel}">
                                <Border Tag="{Binding}" Padding="6,4" CornerRadius="4"
                                        Background="Transparent">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Web で開く (_W)"
                                                      Click="MenuOpenPR_Click" Tag="{Binding}"/>
                                            <Separator/>
                                            <MenuItem Header="ID をコピー (_I)"
                                                      Click="MenuCopyPRId_Click" Tag="{Binding}"/>
                                            <MenuItem Header="タイトルをコピー (_T)"
                                                      Click="MenuCopyPRTitle_Click" Tag="{Binding}"/>
                                            <MenuItem Header="リンクを作成 (_L)"
                                                      Click="MenuCreatePRLink_Click" Tag="{Binding}"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#18FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="PR"
                                                   Foreground="#66AAFF"
                                                   FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="#AACCDD"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   ToolTip="{Binding Title}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
