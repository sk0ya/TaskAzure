<Window x:Class="TaskAzure.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:vm="clr-namespace:TaskAzure.ViewModels"
       WindowStyle="None"
       AllowsTransparency="True"
       Background="Transparent"
       Topmost="True"
       ShowInTaskbar="False"
       Width="260"
       MinHeight="30"
       SizeToContent="Height"
       MaxHeight="600"
       ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      GlassFrameThickness="0"
                      ResizeBorderThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Border x:Name="OuterBorder" Margin="5" CornerRadius="7"
            MouseLeftButtonDown="OuterBorder_MouseLeftButtonDown">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#E6141420"/>
                <Setter Property="BorderBrush" Value="#330078D4"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsLoading}" Value="True">
                        <Setter Property="BorderBrush" Value="#AA0078D4"/>
                        <Setter Property="BorderThickness" Value="1.5"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="1" Opacity="0.55"/>
        </Border.Effect>

        <!-- WorkItem リスト -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 空状態 -->
                <TextBlock Foreground="#334455" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding WorkItems.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="— なし —"/>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding WorkItems}" Padding="3,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkItemViewModel}">
                            <Border Tag="{Binding}" Padding="6,4" CornerRadius="4"
                                    Background="Transparent">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="ID をコピー (_I)"
                                                  Click="MenuCopyId_Click" Tag="{Binding}"/>
                                        <MenuItem Header="タイトルをコピー (_T)"
                                                  Click="MenuCopyTitle_Click" Tag="{Binding}"/>
                                        <MenuItem Header="Web で開く (_W)"
                                                  Click="MenuOpenWeb_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="リンクを作成 (_L)"
                                                  Click="MenuCreateLink_Click" Tag="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#18FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding IdDisplay}"
                                               Foreground="#5BA3D8"
                                               FontFamily="Consolas" FontSize="11"
                                               VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               Foreground="#CCDAEE"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"
                                               Margin="4,0"
                                               ToolTip="{Binding Title}"/>

                                    <Border Grid.Column="2"
                                            Background="{Binding TypeColor}"
                                            CornerRadius="2" Padding="4,1">
                                        <TextBlock Text="{Binding TypeShort}"
                                                   Foreground="White"
                                                   FontSize="9" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
