<Window x:Class="TaskAzure.Windows.CsvCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskAzure.ViewModels"
        xmlns:local="clr-namespace:TaskAzure.Windows"
        Title="子タスクCSV作成"
        Width="800" Height="620"
        MinWidth="600" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E2E">

    <Window.Resources>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#667799"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite"
                                        Grid.Column="0"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        IsHitTestVisible="False"/>
                                    <Path Grid.Column="1"
                                          Data="M0,0 L4,5 L8,0"
                                          Stroke="#8899BB" StrokeThickness="1.5" StrokeLineJoin="Round"
                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                    <ToggleButton x:Name="ToggleBtn"
                                        Grid.Column="0" Grid.ColumnSpan="2"
                                        Background="Transparent" BorderThickness="0"
                                        Focusable="False"
                                        IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                            RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#252535"
                                        BorderBrush="#334466"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer SnapsToDevicePixels="True"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#4455AA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8899BB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#333355"/>
                                <Setter Property="Foreground" Value="#667799"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#333355"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444466"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#223344"/>
            <Setter Property="VerticalGridLinesBrush" Value="#223344"/>
            <Setter Property="RowBackground" Value="#1A1A2E"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2235"/>
            <Setter Property="ColumnHeaderHeight" Value="28"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#99BBDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#223344"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- VariableInput のデータテンプレート -->
        <DataTemplate DataType="{x:Type vm:VariableInput}">
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Label}"
                           VerticalAlignment="Center" Foreground="#AABBDD" FontSize="11"/>
                <!-- ユーザー選択 -->
                <local:UserSearchControl Grid.Column="1"
                          Users="{Binding Users}"
                          SelectedUser="{Binding SelectedUser}">
                    <local:UserSearchControl.Style>
                        <Style TargetType="local:UserSearchControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:VariableKind.User}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </local:UserSearchControl.Style>
                </local:UserSearchControl>
                <!-- テキスト入力 -->
                <TextBox Grid.Column="1"
                         Text="{Binding TextValue, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:VariableKind.Text}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── タイトル ─── -->
        <TextBlock Grid.Row="0" Text="子タスクCSV作成"
                   FontSize="16" FontWeight="SemiBold" Foreground="White"
                   Margin="0,0,0,12"/>

        <!-- ─── 親WorkItem & テンプレート選択 ─── -->
        <Border Grid.Row="1" Background="#141428" BorderBrush="#334466"
                BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="親 WorkItem:"
                           Style="{StaticResource LabelStyle}" VerticalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding ParentItemLabel}"
                           Foreground="#DDEEFF" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,0,8"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="テンプレート:"
                           Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" Foreground="#DDEEFF"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ─── 変数入力 ─── -->
        <Border Grid.Row="2" Background="#141428" BorderBrush="#334466"
                BorderThickness="1" CornerRadius="4" Padding="12,10" Margin="0,0,0,10">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="変数入力"
                               Foreground="#99BBDD" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="前回値を設定"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="10,4" FontSize="11" Margin="0,0,8,0"
                            Click="ApplyLastValues_Click"/>
                    <Button Grid.Column="2" Content="プレビュー更新"
                            Style="{StaticResource SecondaryBtn}"
                            Padding="10,4" FontSize="11"
                            Click="RefreshPreview_Click"/>
                </Grid>

                <!-- ローディング -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#FFAA44" FontSize="11"
                           Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage.Length}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- 変数なし表示 -->
                <TextBlock Text="（このテンプレートに入力変数はありません）"
                           Foreground="#556677" FontSize="11" FontStyle="Italic">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding VariableInputs.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding VariableInputs}"/>
            </StackPanel>
        </Border>

        <!-- ─── CSVプレビュー ─── -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="CSVプレビュー（編集可）"
                           Foreground="#99BBDD" FontSize="11" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="  ※ 変数入力後に「プレビュー更新」を押してください"
                           Foreground="#556677" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Row="1" x:Name="PreviewGrid"
                      AutoGenerateColumns="True"
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionUnit="Cell"
                      HeadersVisibility="Column"
                      AutoGeneratingColumn="PreviewGrid_AutoGeneratingColumn"/>
        </Grid>

        <!-- ─── ボタン行 ─── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="キャンセル" Style="{StaticResource SecondaryBtn}"
                    Margin="0,0,10,0" Click="Cancel_Click"/>
            <Button Content="作成して保存" Style="{StaticResource PrimaryBtn}"
                    Click="Create_Click"/>
        </StackPanel>
    </Grid>
</Window>
