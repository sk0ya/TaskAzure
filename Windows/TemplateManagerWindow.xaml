<Window x:Class="TaskAzure.Windows.TemplateManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="テンプレート管理"
        Width="900" Height="580"
        MinWidth="700" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#1E1E2E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCDDFF"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8899BB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#CCDDFF"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="#CCDDFF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E2A3A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#333355"/>
                                <Setter Property="Foreground" Value="#667799"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#333355"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444466"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#662233"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#883344"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#223344"/>
            <Setter Property="VerticalGridLinesBrush" Value="#223344"/>
            <Setter Property="RowBackground" Value="#1A1A2E"/>
            <Setter Property="AlternatingRowBackground" Value="#1E2235"/>
            <Setter Property="ColumnHeaderHeight" Value="28"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#99BBDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#334466"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDEEFF"/>
            <Setter Property="BorderBrush" Value="#223344"/>
            <Setter Property="Padding" Value="4,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2A3A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="150"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── 左パネル: テンプレート一覧 ─── -->
        <DockPanel Grid.Column="0" Margin="12,12,0,12">
            <TextBlock DockPanel.Dock="Top" Text="テンプレート一覧"
                       FontSize="13" FontWeight="SemiBold" Foreground="White"
                       Margin="0,0,0,8"/>

            <!-- ツールバー -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="新規" Style="{StaticResource SecondaryBtn}"
                        Padding="10,5" Margin="0,0,6,0"
                        Command="{Binding AddTemplateCommand}"/>
                <Button Content="削除" Style="{StaticResource DangerBtn}"
                        Command="{Binding DeleteTemplateCommand}"
                        IsEnabled="{Binding HasSelection}"/>
            </StackPanel>

            <ListBox x:Name="TemplateListBox"
                     ItemsSource="{Binding Templates}"
                     SelectedItem="{Binding SelectedTemplate}"
                     DisplayMemberPath="Name"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </DockPanel>

        <!-- スプリッター -->
        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Stretch"
                      Background="#223344"/>

        <!-- ─── 右パネル: テンプレート編集 ─── -->
        <Grid Grid.Column="2" Margin="12">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="IsEnabled" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="IsEnabled" Value="False"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- テンプレート名 -->
            <TextBlock Grid.Row="0" Text="テンプレート編集"
                       FontSize="13" FontWeight="SemiBold" Foreground="White"
                       Margin="0,0,0,10"/>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="テンプレート名:" VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox Grid.Column="1" x:Name="TemplateNameBox"
                         Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>

            <!-- CSV DataGrid エディター -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- DataGrid ツールバー -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="CSVエディター  " VerticalAlignment="Center"
                               Foreground="#99BBDD" FontSize="11"/>
                    <Button Content="+ 行" Style="{StaticResource SecondaryBtn}"
                            Padding="8,4" FontSize="11" Margin="0,0,4,0"
                            Click="AddRow_Click"/>
                    <Button Content="- 行" Style="{StaticResource DangerBtn}"
                            Padding="8,4" Margin="0,0,4,0"
                            Click="DeleteRow_Click"/>
                    <Button Content="+ 列" Style="{StaticResource SecondaryBtn}"
                            Padding="8,4" FontSize="11" Margin="0,0,4,0"
                            Click="AddColumn_Click"/>
                    <Button Content="- 列" Style="{StaticResource DangerBtn}"
                            Padding="8,4"
                            Click="DeleteColumn_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="CsvGrid"
                          AutoGenerateColumns="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          SelectionUnit="Cell"
                          HeadersVisibility="Column"
                          AutoGeneratingColumn="CsvGrid_AutoGeneratingColumn"/>
            </Grid>

            <!-- 変数ヘルプ -->
            <Border Grid.Row="3" Background="#141428" BorderBrush="#334466"
                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="変数記法のヘルプ" Foreground="#6688AA" FontSize="10" FontWeight="SemiBold"
                               Margin="0,0,0,4"/>
                    <TextBlock FontFamily="Consolas" FontSize="10" Foreground="#7799BB" TextWrapping="Wrap">
                        <Run Text="${parent.Id}"/> <Run Text=" → 親の ID　　" Foreground="#556677"/>
                        <Run Text="${parent.Title}"/> <Run Text=" → 親のタイトル　　" Foreground="#556677"/>
                        <Run Text="${parent.Type}"/> <Run Text=" → 親の種別　　" Foreground="#556677"/>
                        <Run Text="${parent.State}"/> <Run Text=" → 親の状態&#x0a;" Foreground="#556677"/>
                        <Run Text="${0:user}"/> <Run Text=" → ユーザー選択 (同番号=同変数)　　" Foreground="#556677"/>
                        <Run Text="${0:text}"/> <Run Text=" → テキスト入力 (同番号=同変数)" Foreground="#556677"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ボタン行 -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button Content="閉じる" Style="{StaticResource SecondaryBtn}"
                        Margin="0,0,8,0" Click="Close_Click"/>
                <Button Content="保存" Style="{StaticResource PrimaryBtn}"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
