<UserControl x:Class="TaskAzure.Windows.UserSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <!-- メイン表示：選択済みユーザー名 or プレースホルダー -->
        <Border x:Name="MainBorder"
                Background="#2A2A3E"
                BorderBrush="#334466"
                BorderThickness="1"
                CornerRadius="3"
                Cursor="Hand"
                MouseLeftButtonUp="MainBorder_MouseLeftButtonUp">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>

                <!-- 選択済みユーザー名 -->
                <TextBlock x:Name="SelectedLabel"
                           Grid.Column="0"
                           Foreground="#EAF6FF"
                           FontSize="12"
                           Padding="7,5"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           IsHitTestVisible="False"/>

                <!-- 未選択プレースホルダー -->
                <TextBlock x:Name="PlaceholderLabel"
                           Grid.Column="0"
                           Text="（未選択）"
                           Foreground="#556677"
                           FontSize="12"
                           Padding="7,5"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"
                           Visibility="Collapsed"/>

                <!-- 矢印 -->
                <Path Grid.Column="1"
                      x:Name="Arrow"
                      Data="M0,0 L4,5 L8,0"
                      Stroke="#8899BB" StrokeThickness="1.5"
                      StrokeLineJoin="Round"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- ドロップダウンポップアップ -->
        <Popup x:Name="DropdownPopup"
               PlacementTarget="{Binding ElementName=MainBorder}"
               Placement="Bottom"
               AllowsTransparency="True"
               Focusable="False"
               StaysOpen="False"
               Closed="DropdownPopup_Closed">
            <Border Background="#252535"
                    BorderBrush="#334466"
                    BorderThickness="1"
                    CornerRadius="3"
                    MinWidth="{Binding ActualWidth, ElementName=MainBorder}"
                    MaxHeight="260">
                <StackPanel>
                    <!-- 検索ボックス（ポップアップ内） -->
                    <Border BorderBrush="#334466" BorderThickness="0,0,0,1" Padding="6,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍"
                                       FontSize="11" Foreground="#556677"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     Background="Transparent"
                                     Foreground="#EAF6FF"
                                     BorderThickness="0"
                                     FontSize="12"
                                     CaretBrush="White"
                                     SelectionBrush="#2A3A5A"
                                     SelectionOpacity="1"
                                     VerticalContentAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"
                                     PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                            <TextBlock Grid.Column="1"
                                       Text="検索..."
                                       Foreground="#556677"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 結果なし -->
                    <TextBlock x:Name="NoResultsText"
                               Text="（一致するユーザーなし）"
                               Foreground="#556677"
                               FontSize="11"
                               FontStyle="Italic"
                               Padding="8,6"
                               Visibility="Collapsed"/>

                    <!-- ユーザーリスト -->
                    <ListBox x:Name="UserList"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#DDEEFF"
                             FontSize="12"
                             MaxHeight="200"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             KeyboardNavigation.DirectionalNavigation="Cycle"
                             SelectionChanged="UserList_SelectionChanged"
                             PreviewKeyDown="UserList_PreviewKeyDown">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#DDEEFF"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#2A3A5A"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#106EBE"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12"/>
                                    <TextBlock Text="{Binding UniqueName}"
                                               FontSize="10" Foreground="#7799BB"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
